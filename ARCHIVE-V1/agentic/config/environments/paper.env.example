# HaruQuant shared runtime defaults for paper trading
ENVIRONMENT=paper
APP_NAME=haruquant-paper
API_HOST=127.0.0.1
API_PORT=8002
UI_ORIGIN=http://localhost:3000
DATABASE_URL=sqlite:///data/database/haruquant-paper.db
EVENT_BACKEND=inmemory
LOG_LEVEL=INFO
ALLOW_LIVE_MUTATIONS=false
MT5_ENABLED=true
