# HaruQuant Environment Configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit real secrets — use your system keyring or .env file.

# ──────────────────────────────────────────────────────────────
# Environment
# ──────────────────────────────────────────────────────────────
ENVIRONMENT=dev                    # dev | paper | staging | prod
APP_NAME=haruquant-dev
API_HOST=127.0.0.1
API_PORT=8000
UI_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/database/haruquant-dev.db

# ──────────────────────────────────────────────────────────────
# MetaTrader 5 (MT5) — Windows terminal required
# ──────────────────────────────────────────────────────────────
MT5_ENABLED=true
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server_name

# ──────────────────────────────────────────────────────────────
# Gemini API (Google AI Studio / Vertex AI)
# ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
# Optional: override model per tier via env vars
# HARUQUANT_AGENT_MODEL=gemini-3.1-flash-lite-preview
# HARUQUANT_FAST_MODEL=gemini-3.1-flash-lite-preview
# HARUQUANT_PREMIUM_MODEL=gemini-3.1-pro
# HARUQUANT_FALLBACK_MODEL=gemini-3.1-flash-lite-preview
# Generation params
# HARUQUANT_TEMPERATURE=0.2
# HARUQUANT_MAX_TOKENS=4096
# HARUQUANT_TOP_P=0.95
# HARUQUANT_TOP_K=40

# ──────────────────────────────────────────────────────────────
# OpenAI (alternative — set if not using Gemini)
# ──────────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ──────────────────────────────────────────────────────────────
# Ollama (local models — set if using llama/qwen locally)
# ──────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# HARUQUANT_AGENT_MODEL=ollama/llama3.1:70b

# ──────────────────────────────────────────────────────────────
# SMTP / Email Notifications
# ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ──────────────────────────────────────────────────────────────
# Telegram Notifications
# ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ──────────────────────────────────────────────────────────────
# Twilio SMS Notifications
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890

# ──────────────────────────────────────────────────────────────
# Auth & Security
# ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
DATA_ENCRYPTION_KEY=generate_a_fernet_key_here

# ──────────────────────────────────────────────────────────────
# Cost Governance
# ──────────────────────────────────────────────────────────────
# HARUQUANT_MAX_REQUEST_COST=0.10
# HARUQUANT_MAX_WORKFLOW_COST=0.50
# HARUQUANT_MAX_SESSION_COST=2.00
