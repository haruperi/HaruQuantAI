# HaruQuant Environment Configuration Example
# Copy this file to .env and fill in your credentials.
# NEVER commit real secrets — use your system keyring or .env file.

# ──────────────────────────────────────────────────────────────
# Environment
# ──────────────────────────────────────────────────────────────
ENVIRONMENT=dev                    # dev | paper | staging | prod
APP_NAME=haruquant-dev
API_HOST=127.0.0.1
API_PORT=8000
UI_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO
HOME_DIR=your_home_dir_path
DATA_DIR=your_data_dir_path
CACHE_DIR=your_cache_dir_path
AUDIT_DIR=your_audit_dir_path
TIMEZONE=UTC

# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/database/haruquant-dev.db

# ──────────────────────────────────────────────────────────────
# MetaTrader 5 (MT5) — Windows terminal required
# ──────────────────────────────────────────────────────────────
MT5_ENABLED=false
MT5_LOGIN=your_mt5_login_id
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server
MT5_TERMINAL_PATH=C:\\Program Files\\Pepperstone MetaTrader 5\\terminal64.exe
MT5_ENVIRONMENT=demo

# ──────────────────────────────────────────────────────────────
# CTrader
# ──────────────────────────────────────────────────────────────
CTRADER_ENABLED=false
CTRADER_ACCOUNT_ID=your_ctrader_account_id
CTRADER_CLIENT_ID=your_ctrader_client_id
CTRADER_CLIENT_SECRET=your_ctrader_client_secret
CTRADER_ACCESS_TOKEN=your_ctrader_access_token
CTRADER_REFRESH_TOKEN=your_ctrader_refresh_token
CTRADER_REDIRECT_URL=https://api.spotware.com/connect/tradingaccounts/token
CTRADER_ENVIRONMENT=demo

# ──────────────────────────────────────────────────────────────
# Gemini API (Google AI Studio / Vertex AI)
# ──────────────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_api_key
# Optional: override model per tier via env vars
# Gemini models: https://ai.google.dev/gemini/docs/models-overview
# Options include: gemini-3.1-pro-preview, gemini-3.1-flash-lite-preview, gemini-3.1-pro, gemini-3.1-flash-lite-preview
HARUQUANT_AGENT_MODEL=gemini-3.5-flash
HARUQUANT_FAST_MODEL=gemini-3.5-flash
HARUQUANT_PREMIUM_MODEL=gemini-3.5-pro
HARUQUANT_FALLBACK_MODEL=gemini-3.5-flash
# Generation params
HARUQUANT_TEMPERATURE=0.2
HARUQUANT_MAX_TOKENS=4096
HARUQUANT_TOP_P=0.95
HARUQUANT_TOP_K=40

# ──────────────────────────────────────────────────────────────
# OpenAI (alternative — set if not using Gemini)
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
# OPENAI Model options: gpt-5.5, gpt-5.4, gpt-5.4-mini, gpt-5.4-nano

# ──────────────────────────────────────────────────────────────
# Ollama (local models — set if using llama/qwen locally)
# ──────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# HARUQUANT_AGENT_MODEL=ollama/llama3.1:70b

# ──────────────────────────────────────────────────────────────
# SMTP / Email Notifications
# ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password

# ──────────────────────────────────────────────────────────────
# Telegram Notifications
# ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ──────────────────────────────────────────────────────────────
# Twilio SMS Notifications
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890

# ──────────────────────────────────────────────────────────────
# Auth & Security
# ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
DATA_ENCRYPTION_KEY=your_fernet_data_encryption_key_here

# ──────────────────────────────────────────────────────────────
# Cost Governance
# ──────────────────────────────────────────────────────────────
# HARUQUANT_MAX_REQUEST_COST=0.10
# HARUQUANT_MAX_WORKFLOW_COST=0.50
# HARUQUANT_MAX_SESSION_COST=2.00

# --------------------------------------------------------------
# LangChain Tracing
# --------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=HaruQuant
LANGCHAIN_API_KEY=your_langchain_api_key
