# HaruQuantAI Environment Example
# Copy this file to .env and update values locally.
# Do not commit .env.

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
HARUQUANTAI_ENV=development
HARUQUANTAI_DEBUG=true
HARUQUANTAI_APP_NAME=HaruQuantAI
HARUQUANTAI_TIMEZONE=Asia/Dubai

# ---------------------------------------------------------------------
# API
# ---------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------
DATABASE_URL=sqlite:///data/database/haruquantai.db
DATABASE_ECHO=false

# ---------------------------------------------------------------------
# Data Paths
# ---------------------------------------------------------------------
DATA_DIR=data
DATA_CACHE_DIR=data/cache
DATA_LOG_DIR=data/logs
DATA_FIXTURE_DIR=data/fixtures
MARKET_DATA_DIR=data/market_data

# ---------------------------------------------------------------------
# Security / Auth
# ---------------------------------------------------------------------
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_SCHEME=bcrypt

# ---------------------------------------------------------------------
# Trading Safety
# ---------------------------------------------------------------------
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true
REQUIRE_APPROVAL_FOR_LIVE=true
KILL_SWITCH_ENABLED=false
MAX_DAILY_LOSS_PERCENT=2.0
MAX_OPEN_POSITIONS=10
MAX_RISK_PER_TRADE_PERCENT=1.0

# ---------------------------------------------------------------------
# Broker Integrations
# ---------------------------------------------------------------------
MT5_ENABLED=false
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

CTRADER_ENABLED=false
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=

# ---------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

SMS_ENABLED=false
SMS_PROVIDER=
SMS_API_KEY=

# ---------------------------------------------------------------------
# Agentic AI
# ---------------------------------------------------------------------
AGENTIC_ENABLED=false
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
AGENTIC_REQUIRE_EVIDENCE=true
AGENTIC_ALLOW_CONTROLLED_ACTIONS=false

# ---------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE=data/logs/haruquantai.log
