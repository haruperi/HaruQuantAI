{
  "$defs": {
    "AuditEvent": {
      "additionalProperties": false,
      "description": "Immutable, bounded, redacted audit-event envelope version 1.\n\nAttributes:\n    contract_version: The version string, fixed at 'v1'.\n    schema_id: The schema identifier, fixed at 'utils.audit_event.v1'.\n    event_id: Unique trace identifier for the event.\n    timestamp: Aware UTC datetime when the event occurred.\n    domain: Business domain name representing the source.\n    action: Specific action performed within the domain.\n    principal_id: Optional identity of the invoking user or service.\n    request_id: Trace identifier of the outer request.\n    correlation_id: Trace identifier tracking the entire flow.\n    causation_id: Optional trace identifier tracking the direct cause.\n    payload: Immutable, bounded, redacted event data.",
      "properties": {
        "action": {
          "title": "Action",
          "type": "string"
        },
        "causation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Causation Id"
        },
        "contract_version": {
          "const": "v1",
          "title": "Contract Version",
          "type": "string"
        },
        "correlation_id": {
          "title": "Correlation Id",
          "type": "string"
        },
        "domain": {
          "title": "Domain",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "payload": {
          "additionalProperties": {
