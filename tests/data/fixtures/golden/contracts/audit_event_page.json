          },
          "title": "Payload",
          "type": "object"
        },
        "principal_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Principal Id"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "schema_id": {
          "const": "utils.audit_event.v1",
          "title": "Schema Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        }
      },
      "required": [
