{
  "$defs": {
    "AccountBalance": {
      "additionalProperties": false,
      "description": "Exact balance evidence for one asset.",
      "properties": {
        "asset": {
          "title": "Asset",
          "type": "string"
        },
        "available": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Available"
        },
        "total": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Total"
        }
      },
      "required": [
        "asset",
        "total",
        "available"
      ],
      "title": "AccountBalance",
      "type": "object"
    },
    "AccountOrder": {
      "additionalProperties": false,
      "description": "Normalized immutable open-order evidence.",
      "properties": {
        "order_id": {
          "title": "Order Id",
          "type": "string"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Price"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "side": {
          "enum": [
            "BUY",
            "SELL"
          ],
          "title": "Side",
          "type": "string"
        },
        "state": {
          "title": "State",
          "type": "string"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "order_id",
        "symbol",
        "side",
        "state",
        "quantity"
      ],
      "title": "AccountOrder",
      "type": "object"
    },
    "AccountPosition": {
      "additionalProperties": false,
      "description": "Normalized immutable open-position evidence.",
      "properties": {
        "entry_price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entry Price"
        },
        "position_id": {
          "title": "Position Id",
          "type": "string"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "side": {
          "enum": [
            "LONG",
            "SHORT"
          ],
          "title": "Side",
          "type": "string"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "position_id",
        "symbol",
        "side",
        "quantity"
      ],
      "title": "AccountPosition",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Immutable normalized account-state evidence version 1.",
  "properties": {
    "account_id": {
      "title": "Account Id",
      "type": "string"
    },
    "balances": {
      "items": {
        "$ref": "#/$defs/AccountBalance"
      },
      "title": "Balances",
      "type": "array"
    },
    "connected": {
      "title": "Connected",
      "type": "boolean"
    },
    "contract_version": {
      "const": "v1",
      "default": "v1",
      "title": "Contract Version",
      "type": "string"
    },
    "currency": {
      "title": "Currency",
      "type": "string"
    },
    "equity": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Equity"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "margin_available": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Margin Available"
    },
    "margin_used": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Margin Used"
    },
    "orders": {
      "items": {
        "$ref": "#/$defs/AccountOrder"
      },
      "title": "Orders",
      "type": "array"
    },
    "positions": {
      "items": {
        "$ref": "#/$defs/AccountPosition"
      },
      "title": "Positions",
      "type": "array"
    },
    "request_id": {
      "title": "Request Id",
      "type": "string"
    },
    "schema_id": {
      "const": "data.account_state_snapshot.v1",
      "default": "data.account_state_snapshot.v1",
      "title": "Schema Id",
      "type": "string"
    },
    "snapshot_at": {
      "format": "date-time",
      "title": "Snapshot At",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "trading_allowed": {
      "title": "Trading Allowed",
      "type": "boolean"
    }
  },
  "required": [
    "account_id",
    "currency",
    "balances",
    "equity",
    "positions",
    "orders",
    "connected",
    "trading_allowed",
    "source_id",
    "snapshot_at",
    "expires_at",
    "request_id"
  ],
  "title": "AccountStateSnapshot",
  "type": "object"
}
